# Validation messages
msgid "This email is already in use"
msgstr "هذا البريد الإلكتروني مستخدم بالفعل"

msgid "Passwords do not match"
msgstr "كلمات المرور غير متطابقة"

msgid "Phone number is required."
msgstr "رقم الهاتف مطلوب."

msgid "Token is invalid or expired"
msgstr "الرمز المميز غير صالح أو منتهي الصلاحية"

msgid "Invalid user ID"
msgstr "معرف المستخدم غير صالح"

msgid "Current password is incorrect"
msgstr "كلمة المرور الحالية غير صحيحة"

msgid "New passwords do not match"
msgstr "كلمات المرور الجديدة غير متطابقة"

msgid "A user with this email already exists."
msgstr "يوجد مستخدم بهذا البريد الإلكتروني بالفعل."

msgid "This email is not registered"
msgstr "هذا البريد الإلكتروني غير مسجل"

msgid "Organization profile not found"
msgstr "ملف المؤسسة غير موجود"

msgid "End date must be after start date"
msgstr "تاريخ الانتهاء يجب أن يكون بعد تاريخ البداية"

msgid "You do not have permission to perform this action"
msgstr "ليس لديك صلاحية لتنفيذ هذا الإجراء"

msgid "Invalid credentials"
msgstr "بيانات الاعتماد غير صالحة"

msgid "User account is not active"
msgstr "حساب المستخدم غير نشط"

msgid "No active account found with the given credentials"
msgstr "لم يتم العثور على حساب نشط للبيانات المقدمة"

msgid "Arabic"
msgstr "العربية"

msgid "English"
msgstr "الإنجليزية"

